# ── MySQL (Hostinger) ─────────────────────────────────────────────
# Create a MySQL database in hPanel → Databases, then fill these in.
# Import schema.sql via phpMyAdmin before first run.
#
# If these are left empty, the app falls back to a local JSON file
# store in ./data (good for local development without MySQL).

MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=
MYSQL_PASSWORD=
MYSQL_DATABASE=
